# Normalize text in Git and enforce LF for source/docs/config files.
* text=auto eol=lf

*.py text eol=lf
*.pyi text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Keep Windows-native script endings where expected.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary notebooks.
*.ipynb binary
